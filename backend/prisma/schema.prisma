// This is a Prisma schema file for the AI Intelligence Engine additions

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Assuming User and Auction models exist in the main schema
// If not, add them here minimally

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // AI relations
  aiUserMetrics   AIUserMetrics[]
  autoBidConfigs  AutoBidConfig[]
  userBehaviorLogs UserBehaviorLog[]
  sellerInsights   SellerInsight[]
  fraudClusters    FraudCluster[]
}

model Auction {
  id          String   @id @default(cuid())
  title       String
  startingPrice Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // AI relations
  aiAuctionMetrics AIAuctionMetrics[]
  autoBidConfigs   AutoBidConfig[]
  aiPredictionLogs AIPredictionLog[]
  sellerInsights   SellerInsight[]
}

// AI Models

model AIUserMetrics {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalBids       Int      @default(0)
  wins            Int      @default(0)
  avgBidAmount    Float    @default(0)
  winRate         Float    @default(0)
  aggressionScore Float    @default(0) // For win probability
  walletStrength  Float    @default(0) // Calculated from balance
  lastActivity    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([winRate])
  @@index([aggressionScore])
}

model AIAuctionMetrics {
  id                String   @id @default(cuid())
  auctionId         String
  auction           Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  totalBids         Int      @default(0)
  uniqueBidders     Int      @default(0)
  avgBidIncrement   Float    @default(0)
  timeToFirstBid    Int?     // in seconds
  auctionDuration   Int      // in seconds
  finalPrice        Float?
  priceIncrease     Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([auctionId])
  @@index([totalBids])
  @@index([finalPrice])
}

model AutoBidConfig {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  auctionId         String?
  auction           Auction? @relation(fields: [auctionId], references: [id], onDelete: SetNull)
  maxAmount         Float
  increment         Float    @default(100)
  isActive          Boolean  @default(true)
  winProbabilityThreshold Float @default(0.45)
  fraudRiskThreshold     Float @default(0.6)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, auctionId])
  @@index([userId])
  @@index([auctionId])
  @@index([isActive])
}

model AIPredictionLog {
  id            String   @id @default(cuid())
  auctionId     String
  auction       Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  userId        String?
  predictionType String  // e.g., "win_probability", "fraud_score"
  predictionValue Float
  confidence     Float   @default(0)
  factors       Json     // Store the factors used
  result        String?  // e.g., "bid_placed", "blocked"
  createdAt     DateTime @default(now())

  @@index([auctionId])
  @@index([userId])
  @@index([predictionType])
  @@index([createdAt])
}

model UserBehaviorLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      String   // e.g., "bid", "view", "login"
  metadata    Json     // Additional data
  ipAddress   String?
  userAgent   String?
  timestamp   DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([timestamp])
}

model FraudCluster {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clusterId       String   // Group similar behaviors
  fraudScore      Float    @default(0)
  bidRingScore    Float    @default(0)
  behaviorSimilarity Float @default(0)
  walletAnomaly   Float    @default(0)
  isFrozen        Boolean  @default(false)
  frozenAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([clusterId])
  @@index([fraudScore])
  @@index([isFrozen])
}

model SellerInsight {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  auctionId           String?
  auction             Auction? @relation(fields: [auctionId], references: [id], onDelete: SetNull)
  insightType         String   // e.g., "starting_price", "timing", "description"
  recommendation      String
  expectedImpact      Float    @default(0) // Expected price increase %
  confidence          Float    @default(0)
  applied             Boolean  @default(false)
  appliedAt           DateTime?
  createdAt           DateTime @default(now())

  @@index([userId])
  @@index([auctionId])
  @@index([insightType])
  @@index([applied])
}

model EmbeddingVector {
  id        String   @id @default(cuid())
  entityId  String   // ID of the entity (user, auction, etc.)
  entityType String  // "user", "auction", "product"
  vector    Unsupported("vector(1536)")? // For pgvector, assuming 1536 for OpenAI
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([entityId])
  @@index([entityType])
  @@unique([entityId, entityType])
}

// Enable pgvector extension if needed
// In migration, run: CREATE EXTENSION IF NOT EXISTS vector;

// Training Datasets

model AuctionTrainingData {
  id                      String   @id @default(cuid())
  userId                  String
  auctionId               String
  bidAmount               Float
  previousBidAmount       Float?
  bidIncrement            Float
  timeRemainingSeconds    Int
  totalAuctionDuration    Int
  walletBalance           Float
  walletToCurrentPriceRatio Float
  userHistoricalWinRate   Float
  userAggressionScore     Float
  auctionVolatilityScore  Float
  numberOfCompetitors     Int
  wasHighestBid           Boolean
  finalOutcome            String  // "WIN" or "LOSS"
  createdAt               DateTime @default(now())

  @@index([userId])
  @@index([auctionId])
  @@index([createdAt])
  @@index([finalOutcome])
}

model FraudTrainingData {
  id                      String   @id @default(cuid())
  userId                  String
  auctionId               String?
  bidFrequencyPerMinute   Float
  avgIncrement            Float
  sessionDuration         Int
  rechargeAmountBeforeBid Float?
  deviceFingerprintHash   String
  ipHash                  String
  similarityClusterScore  Float
  walletAbuseScore        Float
  labeledFraud            Boolean
  createdAt               DateTime @default(now())

  @@index([userId])
  @@index([auctionId])
  @@index([createdAt])
  @@index([labeledFraud])
}

model AISubscription {
  id              String   @id @default(cuid())
  userId          String   @unique
  planType        String   // "FREE", "PRO", "ELITE"
  featuresEnabled Json     // JSON object of enabled features
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ModelMetrics {
  id          String   @id @default(cuid())
  modelName   String
  version     String
  accuracy    Float
  precision   Float
  recall      Float
  f1Score     Float
  trainedAt   DateTime @default(now())

  @@index([modelName])
  @@index([version])
  @@index([trainedAt])
}
