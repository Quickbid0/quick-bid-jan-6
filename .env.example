# =============================================================================
# QUICKMELA ENVIRONMENT CONFIGURATION TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# Server Configuration
PORT=4010
NODE_ENV=development

# Frontend Configuration
VITE_RAZORPAY_KEY=your_razorpay_key_id_here
VITE_AUTH_MODE=real
VITE_SERVER_URL=http://localhost:4010
VITE_APP_URL=http://localhost:3000
VITE_API_URL=http://localhost:4010
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_GA_TRACKING_ID=your_google_analytics_id_here

# Payment Integration - Razorpay (Primary)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# Payment Integration - PayU (Secondary - Optional)
PAYU_KEY=your_payu_key_here
PAYU_SALT=your_payu_salt_here
PAYU_WEBHOOK_SALT=your_payu_webhook_salt_here

# Payment Integration - Cashfree (Secondary - Optional)
CASHFREE_APP_ID=your_cashfree_app_id_here
CASHFREE_SECRET_KEY=your_cashfree_secret_key_here

# SMS Integration - For OTP and notifications
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# Email Integration - For notifications and receipts
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM=noreply@quickmela.com

# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/quickmela_dev"

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password_here

# JWT Configuration
JWT_SECRET=your_256_character_jwt_secret_here_minimum
SESSION_SECRET=your_32_character_session_secret_here

# Email Configuration (Alternative to SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=QuickMela <your_email@gmail.com>
FRONTEND_URL=http://localhost:3000

# Push Notifications
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:your_email@example.com

# WhatsApp Business Cloud API Integration
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_whatsapp_webhook_verify_token_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_whatsapp_business_account_id_here

# =============================================================================
# PRODUCTION CHECKLIST REMINDERS
# =============================================================================
# [ ] Replace all placeholder values with actual credentials
# [ ] Use strong, unique secrets for JWT and sessions (256+ chars)
# [ ] Configure proper CORS origins for production domains
# [ ] Set NODE_ENV=production in production environment
# [ ] Use production-grade database and Redis URLs
# [ ] Configure proper SSL/TLS certificates
# [ ] Set up monitoring and error tracking (Sentry, DataDog)
# [ ] Configure proper rate limiting and security headers
# [ ] Set up log aggregation and alerting
# [ ] Configure automated backups and disaster recovery
# [ ] Test all payment flows with real credentials
# [ ] Verify SMS/Email notifications work
# [ ] Run comprehensive security audit
# [ ] Perform load testing with realistic user scenarios
# [ ] Set up proper CI/CD pipelines with security scanning
# =============================================================================
